# Django settings (required at startup)
DJANGO_SECRET_KEY=change-this-to-a-long-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Cloudflare R2 media storage (required in production)
# Leave R2_BUCKET_NAME empty locally to use the ignored media/ directory.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_CUSTOM_DOMAIN=

# Cloudways API (required for Milestone 2+)
CLOUDWAYS_API_KEY=

# Cloudflare API (required for Milestone 2+)
# Token must have Zone:Read and DNS:Edit permissions scoped to all relevant zones.
CLOUDFLARE_API_TOKEN=

# Email / SMTP (required for Milestone 2+)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
