# Generator app credentials (required at startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
SECRET_KEY=change-this-to-a-long-random-secret

# Cloudways API (required for Milestone 2+)
CLOUDWAYS_API_KEY=

# Cloudflare API (required for Milestone 2+)
# Token must have Zone:Read and DNS:Edit permissions scoped to all relevant zones.
CLOUDFLARE_API_TOKEN=

# Email / SMTP (required for Milestone 2+)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
